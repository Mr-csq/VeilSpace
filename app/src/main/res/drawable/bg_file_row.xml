<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <gradient android:angle="0" android:startColor="#4D75E7F5" android:endColor="#33A88AFF" />
            <stroke android:width="1dp" android:color="@color/space_primary" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/space_surface_pressed" />
            <stroke android:width="1dp" android:color="@color/space_outline_strong" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/space_surface" />
            <stroke android:width="1dp" android:color="@color/space_outline" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
