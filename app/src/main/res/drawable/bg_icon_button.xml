<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/ui_icon_button_pressed" />
            <stroke android:width="1dp" android:color="@color/space_outline_strong" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/ui_icon_button" />
            <stroke android:width="1dp" android:color="@color/space_outline" />
        </shape>
    </item>
</selector>
