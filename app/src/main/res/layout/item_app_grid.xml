<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="126dp"
    android:layout_margin="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/space_surface"
    app:cardCornerRadius="20dp"
    app:cardElevation="7dp"
    app:strokeColor="@color/space_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="6dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/iv_app_icon"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:contentDescription="应用图标"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center|top"
            android:includeFontPadding="false"
            android:maxLines="2"
            android:textColor="@color/space_text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_app_status"
            android:layout_width="wrap_content"
            android:layout_height="18dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:textColor="@color/space_error"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
