<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/space_background"
    tools:context=".ui.home.AppManagementListFragment">

    <com.system.launcher.tools.ui.common.AnimatedSpaceBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:id="@+id/page_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <ImageButton
                android:id="@+id/btn_back"
                style="@style/Widget.PrivacySpace.IconButton"
                android:layout_marginEnd="10dp"
                android:contentDescription="返回"
                android:src="@drawable/ic_arrow_back_24"
                app:tint="@color/space_text_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_list_eyebrow"
                    style="@style/TextAppearance.PrivacySpace.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="APP DIRECTORY" />

                <TextView
                    android:id="@+id/tv_list_title"
                    style="@style/TextAppearance.PrivacySpace.PageTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    tools:text="应用设置" />

                <TextView
                    android:id="@+id/tv_list_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textColor="@color/space_text_secondary"
                    android:textSize="13sp"
                    tools:text="管理显示、后台策略、卸载与应用状态" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_refresh"
                style="@style/Widget.PrivacySpace.IconButton"
                android:contentDescription="刷新"
                android:src="@drawable/ic_refresh_24"
                app:tint="@color/space_primary" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_mode_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingTop="4dp"
            android:paddingEnd="20dp"
            android:paddingBottom="7dp"
            android:textColor="@color/space_text_secondary"
            android:textSize="13sp"
            tools:text="点击应用进入详情，共 12 个记录" />

        <TextView
            android:id="@+id/tv_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_management_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:text="正在更新应用状态"
            android:textColor="@color/space_primary"
            android:textSize="12sp"
            android:visibility="gone" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_management_apps"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="24dp" />

            <LinearLayout
                android:id="@+id/empty_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginHorizontal="28dp"
                android:background="@drawable/bg_glass_panel"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="28dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_empty_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/space_text_primary"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    tools:text="暂无应用记录" />

                <TextView
                    android:id="@+id/tv_empty_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:textColor="@color/space_text_secondary"
                    android:textSize="14sp"
                    tools:text="安装应用后会出现在这里" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
