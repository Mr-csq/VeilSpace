<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/space_surface"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:strokeColor="@color/space_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="90dp"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingVertical="13dp">

        <ImageView
            android:id="@+id/iv_app_icon"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:contentDescription="应用图标"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_app_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/space_text_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="应用名称" />

            <TextView
                android:id="@+id/tv_package_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="middle"
                android:maxLines="1"
                android:textColor="@color/space_text_tertiary"
                android:textSize="11sp"
                tools:text="com.example.app" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/space_text_secondary"
                android:textSize="12sp"
                tools:text="首页显示 · 已安装 · 可启动" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_management_badge"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/space_primary_bright"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="首页" />

        <ImageView
            android:id="@+id/iv_trailing"
            android:layout_width="34dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:contentDescription="进入详情"
            android:padding="8dp"
            android:src="@drawable/ic_chevron_right_24"
            app:tint="@color/space_text_tertiary" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
