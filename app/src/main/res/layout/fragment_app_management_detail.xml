<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:orientation="vertical"
    tools:context=".ui.home.AppManagementDetailFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:src="@android:drawable/ic_media_previous" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="应用详情"
            android:textColor="?android:textColorPrimary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_refresh_status"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="刷新状态"
            android:src="@android:drawable/ic_popup_sync" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingBottom="18dp">

                <ImageView
                    android:id="@+id/iv_app_icon"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:contentDescription="应用图标"
                    android:scaleType="fitCenter" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_app_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="应用名称" />

                    <TextView
                        android:id="@+id/tv_package_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="12sp"
                        tools:text="com.example.app" />

                    <TextView
                        android:id="@+id/tv_status_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="?android:textColorSecondary"
                        android:textSize="13sp"
                        tools:text="首页显示 · 已安装 · 可启动" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:text="显示"
                android:textColor="?android:textColorPrimary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_show"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="在首页显示" />

            <TextView
                android:id="@+id/tv_show_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="18dp"
                android:text="关闭后应用仍保留在隐藏空间，只是不出现在首页。"
                android:textColor="?android:textColorSecondary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="运行策略"
                android:textColor="?android:textColorPrimary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_keep_alive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="允许后台运行" />

            <TextView
                android:id="@+id/tv_keep_alive_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="18dp"
                android:textColor="?android:textColorSecondary"
                android:textSize="12sp"
                tools:text="关闭后离开前台会自动隐藏，减少桌面残留。" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="状态"
                android:textColor="?android:textColorPrimary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_status_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="3dp"
                android:textColor="?android:textColorSecondary"
                android:textSize="13sp"
                tools:text="入口来源：当前发现\n安装验证：确认已安装\n启动验证：可启动\n图标状态：OK" />

            <TextView
                android:id="@+id/tv_diagnostic_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingBottom="18dp"
                android:textColor="?attr/colorError"
                android:textSize="13sp"
                tools:text="应用图标需要修复" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="操作"
                android:textColor="?android:textColorPrimary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_refresh_icon"
                style="?attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:text="刷新应用图标" />

            <Button
                android:id="@+id/btn_uninstall_app"
                style="?attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:text="从隐藏空间卸载" />

            <Button
                android:id="@+id/btn_remove_record"
                style="?attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:text="移除记录" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
