<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/space_background"
    tools:context=".ui.home.AppManagementDetailFragment">

    <com.system.launcher.tools.ui.common.AnimatedSpaceBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:id="@+id/page_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp">

            <ImageButton
                android:id="@+id/btn_back"
                style="@style/Widget.PrivacySpace.IconButton"
                android:layout_marginEnd="10dp"
                android:contentDescription="返回"
                android:src="@drawable/ic_arrow_back_24"
                app:tint="@color/space_text_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TextAppearance.PrivacySpace.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APP PROFILE" />

                <TextView
                    style="@style/TextAppearance.PrivacySpace.PageTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="应用详情" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_refresh_status"
                style="@style/Widget.PrivacySpace.IconButton"
                android:contentDescription="刷新状态"
                android:src="@drawable/ic_refresh_24"
                app:tint="@color/space_primary" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_brand_hero"
                    android:gravity="center_vertical"
                    android:minHeight="112dp"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:id="@+id/iv_app_icon"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:contentDescription="应用图标"
                        android:scaleType="fitCenter" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_app_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:textColor="@color/space_text_primary"
                            android:textSize="21sp"
                            android:textStyle="bold"
                            tools:text="应用名称" />

                        <TextView
                            android:id="@+id/tv_package_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="middle"
                            android:maxLines="1"
                            android:textColor="@color/space_text_secondary"
                            android:textSize="12sp"
                            tools:text="com.example.app" />

                        <TextView
                            android:id="@+id/tv_status_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="9dp"
                            android:textColor="@color/space_primary_bright"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="首页显示 · 已安装 · 可启动" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    style="@style/TextAppearance.PrivacySpace.SectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="9dp"
                    android:text="空间设置" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_panel"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_show"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="在首页显示"
                        android:textColor="@color/space_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:thumbTint="@color/space_switch_thumb"
                        app:trackTint="@color/space_switch_track" />

                    <TextView
                        android:id="@+id/tv_show_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingEnd="64dp"
                        android:paddingBottom="14dp"
                        android:text="关闭后应用仍保留在隐藏空间。"
                        android:textColor="@color/space_text_secondary"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/space_divider" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_keep_alive"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="允许后台运行"
                        android:textColor="@color/space_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:thumbTint="@color/space_switch_thumb"
                        app:trackTint="@color/space_switch_track" />

                    <TextView
                        android:id="@+id/tv_keep_alive_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingEnd="64dp"
                        android:paddingBottom="14dp"
                        android:textColor="@color/space_text_secondary"
                        android:textSize="12sp"
                        tools:text="关闭后离开前台会自动隐藏。" />
                </LinearLayout>

                <TextView
                    style="@style/TextAppearance.PrivacySpace.SectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="9dp"
                    android:text="状态诊断" />

                <TextView
                    android:id="@+id/tv_status_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_panel"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="5dp"
                    android:padding="16dp"
                    android:textColor="@color/space_text_secondary"
                    android:textSize="13sp"
                    tools:text="入口来源：当前发现&#10;安装验证：确认已安装&#10;启动验证：可启动&#10;图标状态：正常" />

                <TextView
                    android:id="@+id/tv_diagnostic_reason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_error_notice"
                    android:padding="14dp"
                    android:textColor="@color/space_error"
                    android:textSize="13sp"
                    tools:text="应用图标需要修复" />

                <TextView
                    style="@style/TextAppearance.PrivacySpace.SectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="4dp"
                    android:text="操作" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_refresh_icon"
                    style="@style/Widget.PrivacySpace.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:text="刷新应用图标"
                    app:icon="@drawable/ic_refresh_24"
                    app:iconGravity="textStart"
                    app:iconTint="@color/space_primary_bright" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_uninstall_app"
                    style="@style/Widget.PrivacySpace.DangerTextButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:text="从隐藏空间卸载"
                    app:icon="@drawable/ic_delete_24"
                    app:iconTint="@color/space_error" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_remove_record"
                    style="@style/Widget.PrivacySpace.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="4dp"
                    android:text="仅移除记录" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
