<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.files.PersonalMediaImportActivity">

    <com.system.launcher.tools.ui.common.AnimatedSpaceBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/page_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:minHeight="640dp"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="48dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <TextView
                style="@style/TextAppearance.PrivacySpace.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/media_import_eyebrow" />

            <TextView
                android:id="@+id/tv_title"
                style="@style/TextAppearance.PrivacySpace.PageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="@string/media_import_copying_title" />

            <TextView
                android:id="@+id/tv_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="@string/media_import_preparing"
                android:textColor="@color/space_text_secondary"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="34dp"
                android:background="@drawable/bg_glass_panel"
                android:orientation="vertical"
                android:padding="24dp">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_copy"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="100"
                    app:indicatorColor="@color/space_primary"
                    app:trackColor="@color/space_surface_soft"
                    app:trackCornerRadius="4dp"
                    app:trackThickness="8dp" />

                <TextView
                    android:id="@+id/tv_current_file"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:ellipsize="middle"
                    android:gravity="center"
                    android:maxLines="2"
                    android:textColor="@color/space_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="IMG_20260714_102400.jpg" />

                <TextView
                    android:id="@+id/tv_destination"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/media_import_destination"
                    android:textColor="@color/space_text_tertiary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_failures"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:textColor="@color/space_error"
                    android:textSize="13sp"
                    android:visibility="gone"
                    tools:text="复制失败：example.jpg"
                    tools:visibility="visible" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_done"
                style="@style/Widget.PrivacySpace.PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/media_import_done"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
