<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/space_background"
    tools:context=".ui.automation.AutomationFragment">

    <com.system.launcher.tools.ui.common.AnimatedSpaceBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:id="@+id/page_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <ImageButton
                android:id="@+id/btn_back"
                style="@style/Widget.PrivacySpace.IconButton"
                android:layout_marginEnd="10dp"
                android:contentDescription="@string/automation_back"
                android:src="@drawable/ic_arrow_back_24"
                app:tint="@color/space_text_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TextAppearance.PrivacySpace.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/automation_eyebrow" />

                <TextView
                    style="@style/TextAppearance.PrivacySpace.PageTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/automation_title" />
            </LinearLayout>
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_panel"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TextAppearance.PrivacySpace.SectionTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/automation_master_switch" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="@string/automation_master_summary"
                            android:textColor="@color/space_text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_enabled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/automation_enable_description" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_glass_panel"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextAppearance.PrivacySpace.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/automation_current_state" />

                    <TextView
                        android:id="@+id/tv_current_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/space_text_primary"
                        android:textSize="14sp"
                        tools:text="计划处于关闭时段" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/automation_next_execution"
                        android:textColor="@color/space_text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tv_next_boundary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/space_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="开始 · 2026-07-15 周三 09:00" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_glass_panel"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextAppearance.PrivacySpace.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/automation_boundary_time" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_start_time"
                            style="@style/Widget.PrivacySpace.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:text="@string/automation_default_start_time" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_end_time"
                            style="@style/Widget.PrivacySpace.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:text="@string/automation_default_end_time" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_time_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/space_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_glass_panel"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextAppearance.PrivacySpace.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/automation_date_mode" />

                    <RadioGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/radio_china_workday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/automation_china_workday"
                            android:textColor="@color/space_text_primary" />

                        <RadioButton
                            android:id="@+id/radio_custom_weekdays"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/automation_custom_weekdays"
                            android:textColor="@color/space_text_primary" />
                    </RadioGroup>

                    <LinearLayout
                        android:id="@+id/custom_weekdays_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <CheckBox android:id="@+id/check_monday" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/automation_weekday_monday" />
                            <CheckBox android:id="@+id/check_tuesday" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/automation_weekday_tuesday" />
                            <CheckBox android:id="@+id/check_wednesday" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/automation_weekday_wednesday" />
                            <CheckBox android:id="@+id/check_thursday" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/automation_weekday_thursday" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <CheckBox android:id="@+id/check_friday" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/automation_weekday_friday" />
                            <CheckBox android:id="@+id/check_saturday" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/automation_weekday_saturday" />
                            <CheckBox android:id="@+id/check_sunday" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/automation_weekday_sunday" />
                            <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_workday_data"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/space_text_secondary"
                        android:textIsSelectable="true"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_glass_panel"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextAppearance.PrivacySpace.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/automation_selected_apps" />

                    <TextView
                        android:id="@+id/tv_selected_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/space_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="@string/automation_notification_capability"
                        android:textColor="@color/space_text_secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:id="@+id/apps_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="vertical" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_glass_panel"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextAppearance.PrivacySpace.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/automation_exact_alarm" />

                    <TextView
                        android:id="@+id/tv_exact_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:textColor="@color/space_text_secondary"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_exact_permission"
                        style="@style/Widget.PrivacySpace.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/automation_exact_alarm_permission" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_glass_panel"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/TextAppearance.PrivacySpace.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/automation_last_result" />

                    <TextView
                        android:id="@+id/tv_last_result"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/space_text_secondary"
                        android:textIsSelectable="true"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_validation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_error_notice"
                    android:padding="12dp"
                    android:textColor="@color/space_text_primary"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save"
                    style="@style/Widget.PrivacySpace.PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/automation_save" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="@string/automation_keep_alive_explanation"
                    android:textColor="@color/space_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</FrameLayout>
