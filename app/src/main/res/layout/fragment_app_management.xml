<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_background"
    android:orientation="vertical"
    tools:context=".ui.home.AppManagementFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/btn_back"
            style="@style/Widget.PrivacySpace.IconButton"
            android:layout_marginEnd="8dp"
            android:contentDescription="返回"
            android:src="@drawable/ic_arrow_back_24"
            app:tint="@color/ui_text_secondary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/TextAppearance.PrivacySpace.PageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="应用管理" />

            <TextView
                android:id="@+id/tv_management_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="查看全部应用和异常记录"
                android:textColor="@color/ui_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_refresh"
            style="@style/Widget.PrivacySpace.IconButton"
            android:contentDescription="刷新"
            android:src="@drawable/ic_refresh_24"
            app:tint="@color/ui_text_secondary" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/mode_group"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="2dp"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_all_apps"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="全部应用"
            android:textSize="14sp"
            app:cornerRadius="20dp"
            app:strokeColor="@color/ui_outline" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_issue_apps"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="问题处理"
            android:textSize="14sp"
            app:cornerRadius="20dp"
            app:strokeColor="@color/ui_outline" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <TextView
        android:id="@+id/tv_mode_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        android:textColor="@color/ui_text_secondary"
        android:textSize="13sp"
        tools:text="点击应用进入详情页管理显示、后台、卸载和状态" />

    <TextView
        android:id="@+id/tv_loading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="6dp"
        android:text="正在更新应用状态"
        android:textColor="@color/ui_primary"
        android:textSize="13sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_management_apps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="16dp" />

    <LinearLayout
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_empty_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂无应用记录"
            android:textColor="@color/ui_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_empty_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="安装应用后会出现在这里，也可以点击右上角刷新"
            android:textColor="@color/ui_text_secondary"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>

