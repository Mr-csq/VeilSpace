<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.PrivacySpace" parent="android:style/Widget" />
    <style name="ShapeAppearance.PrivacySpace" parent="ShapeAppearance.Material3.Corner.None" />

    <style name="Widget.PrivacySpace.IconButton">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:background">@drawable/bg_icon_button</item>
        <item name="android:padding">12dp</item>
        <item name="android:tint">@color/space_text_secondary</item>
        <item name="android:stateListAnimator">@animator/space_elevation</item>
    </style>

    <style name="Widget.PrivacySpace.IconButton.Primary" parent="Widget.PrivacySpace.IconButton">
        <item name="android:background">@drawable/bg_icon_button_primary</item>
        <item name="android:tint">@color/space_on_accent</item>
    </style>

    <style name="Widget.PrivacySpace.IconButton.OnDark" parent="Widget.PrivacySpace.IconButton">
        <item name="android:background">@drawable/bg_icon_button_on_dark</item>
        <item name="android:tint">@color/white</item>
    </style>

    <style name="Widget.PrivacySpace.PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
        <item name="backgroundTint">@color/space_primary</item>
        <item name="android:textColor">@color/space_on_accent</item>
        <item name="rippleColor">@color/space_secondary</item>
        <item name="android:stateListAnimator">@animator/space_elevation</item>
    </style>

    <style name="Widget.PrivacySpace.TextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">26dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/space_primary</item>
        <item name="rippleColor">@color/ui_primary_container</item>
    </style>

    <style name="Widget.PrivacySpace.TonalButton" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">26dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textSize">15sp</item>
        <item name="backgroundTint">@color/ui_primary_container</item>
        <item name="android:textColor">@color/space_primary_bright</item>
        <item name="rippleColor">@color/space_primary</item>
    </style>

    <style name="Widget.PrivacySpace.DangerTextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">26dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textColor">@color/space_error</item>
        <item name="backgroundTint">@color/space_error_container</item>
        <item name="rippleColor">@color/space_error</item>
    </style>

    <style name="Widget.PrivacySpace.SegmentItem" parent="android:style/Widget.Button">
        <item name="android:layout_height">match_parent</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:background">@drawable/bg_segment_item</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/space_segment_item_text</item>
    </style>

    <style name="TextAppearance.PrivacySpace.Eyebrow" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/space_primary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.PrivacySpace.PageTitle" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/space_text_primary</item>
        <item name="android:textSize">29sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.PrivacySpace.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/space_text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="ShapeAppearance.PrivacySpace.Dialog">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <style name="ThemeOverlay.PrivacySpace.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.PrivacySpace.Dialog</item>
        <item name="colorSurface">@color/space_surface_high</item>
        <item name="colorOnSurface">@color/space_text_primary</item>
        <item name="colorPrimary">@color/space_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.PrivacySpace.TextButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.PrivacySpace.TextButton</item>
        <item name="android:windowAnimationStyle">@style/Animation.PrivacySpace.Dialog</item>
    </style>

    <style name="Animation.PrivacySpace.Dialog" parent="@android:style/Animation.Dialog">
        <item name="android:windowEnterAnimation">@anim/dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit</item>
    </style>
</resources>
